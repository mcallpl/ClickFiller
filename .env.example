# ClickFiller Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git - it contains secrets

# Google Gemini API Configuration
# Get your API key from: https://aistudio.google.com  (Get API key)
# In this project the value is sourced from the shared vault ($vault_gemini_api_key).
GEMINI_API_KEY=your-api-key-here
# Model for form analysis. Use gemini-2.5-flash or higher — flash-lite returns
# unusable coordinates for this app. gemini-2.5-pro = best positioning, higher cost.
GEMINI_MODEL=gemini-2.5-flash

# Application Environment
# Values: development, production, staging
NODE_ENV=development

# Server Configuration
PORT=3001
HOST=localhost

# Logging
# Values: debug, info, warn, error
LOG_LEVEL=info

# CORS Configuration (production)
# Comma-separated list of allowed origins
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Database (future use)
# DATABASE_URL=postgresql://user:password@localhost:5432/clickfiller

# Session Configuration
# SESSION_SECRET=your-random-secret-key-min-32-chars
# SESSION_TIMEOUT=3600000

# Monitoring
# Enable monitoring endpoints
MONITORING_ENABLED=true

# File Upload
# Maximum file size for image uploads (in bytes)
MAX_UPLOAD_SIZE=20971520

# Feature Flags
# FEATURE_OCTOPARSER=true
# FEATURE_AUTO_SAVE=true
